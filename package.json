{
  "name": "local-service-seo-demo",
  "version": "1.0.0",
  "description": "Local service SEO demo site with generated location and service landing pages.",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "build": "echo 'No build step needed for static site'",
    "preview": "cd public && live-server --port=8080 --open=/index.html --no-browser",
    "generate-seo": "node scripts/generate-location-pages.js",
    "add-favicons": "node scripts/add-favicons.js",
    "add-recaptcha": "node scripts/add-recaptcha.js",
    "seo-build": "npm run generate-seo && npm run build"
  },
  "keywords": [
    "local-seo",
    "lead-generation",
    "service-business",
    "static-site",
    "seo-demo"
  ],
  "author": "Stephen Weaver",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "nodemailer": "^6.9.7"
  },
  "devDependencies": {
    "live-server": "^1.2.0"
  }
}
